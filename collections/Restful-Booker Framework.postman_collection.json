    {
      "name": "Get Booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Get Booking Details Successful\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "\r",
              "pm.test(\"Verify First Name is Sahan\", function () {\r",
              "    pm.expect(jsonData.firstname).to.eql(\"Sahan\");\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Verify Total Price is correct\", function () {\r",
              "    pm.expect(jsonData.totalprice).to.eql(150);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Verify Booking Dates exist\", function () {\r",
              "    pm.expect(jsonData.bookingdates).to.be.an('object');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
